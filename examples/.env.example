# ─────────────────────────────────────────────────────────────
# Environment for the example compose files.
# Copy to `.env` next to your docker-compose file and fill in real values:
#     cp examples/.env.example .env
# Compose substitutes ${VAR} from .env automatically. Keep .env out of git.
# Full reference: docs/CONFIGURATION.md
# ─────────────────────────────────────────────────────────────

# ── Telegram (required for delivery) ──
# Bot token from @BotFather
TELEGRAM_BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11
# Chat id from @userinfobot. Comma-separate to deliver to multiple chats:
#   TELEGRAM_CHAT_ID=-1001234567890,123456789
TELEGRAM_CHAT_ID=-1001234567890

# ── Large files > 50 MB (optional) ──
# App credentials from https://my.telegram.org/apps. Needed for either large-file
# route: the built-in MTProto uploader (docker-compose.large-files-mtproto.yml)
# or the self-hosted Bot API server (docker-compose.large-files-server.yml).
TELEGRAM_API_ID=12345678
TELEGRAM_API_HASH=abcdef1234567890abcdef1234567890

# ── Encryption (optional) ──
# GPG passphrase for AES-256 encryption at rest. Leave empty to disable.
BACKUP_ENCRYPTION_KEY=

# Tip: restore from Telegram with the id shown in each backup's caption:
#   docker exec -it <container> restore --from-telegram <message_id>
